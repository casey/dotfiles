[advice]
skippedCherryPicks = false

[alias]
co = checkout

[color]
branch = auto
diff   = auto
status = auto
ui     = true

[color "diff"]
meta       = 11
frag       = magenta bold
commit     = yellow bold
old        = red bold
new        = green bold
whitespace = red reverse

[color "diff-highlight"]
oldNormal    = red bold
oldHighlight = red bold 52
newNormal    = green bold
newHighlight = green bold 22

[commit]
verbose = true

[core]
autocrlf     = false
excludesfile = ~/.gitignore.global
pager        = delta
quotepath    = false
trustctime   = false

[credential]
helper = osxkeychain

[diff]
tool = meld

[difftool]
prompt = false

[difftool "meld"]
cmd = open -W -a Meld --args \"$LOCAL\" \"$PWD/$REMOTE\"
trustExitCode = true

[fetch]
prune = true

[filter "lfs"]
clean = git-lfs clean -- %f
process = git-lfs filter-process
required = true
smudge = git-lfs smudge -- %f

[github]
user = casey

[gpg]
program = gpg

[http]
cookiefile = ~/.gitcookies

[init]
defaultBranch = master

[merge]
conflictstyle = zdiff3
tool = meld

[mergetool]
prompt = false

[mergetool "meld"]
cmd = open -W -a Meld --args --auto-merge \"$PWD/$LOCAL\" \"$PWD/$BASE\" \"$PWD/$REMOTE\" --output = \"$PWD/$MERGED\"
trustExitCode = true

[pull]
default = current
rebase = true

[push]
default = current

[rebase]
autoStash = true

