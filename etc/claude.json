{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "IS_DEMO": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cargo dep *)",
      "Bash(rg --files)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f AGENTS.md ] && [ ! -e CLAUDE.md ] && jq -n --rawfile c AGENTS.md '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:(\"Project instructions from ./AGENTS.md:\\n\\n\"+$c)}}' || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "xhigh",
  "awaySummaryEnabled": false,
  "verbose": true,
  "preferredNotifChannel": "notifications_disabled"
}
