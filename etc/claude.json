{
  "allowedMcpServers": [],
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "autoMemoryEnabled": false,
  "awaySummaryEnabled": false,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false",
    "IS_DEMO": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "[ -f AGENTS.md ] && [ ! -e CLAUDE.md ] && jq -n --rawfile c AGENTS.md '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:(\"Project instructions from ./AGENTS.md:\\n\\n\"+$c)}}' || true",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "claude-fable-5[1m]",
  "permissions": {
    "allow": [
      "Bash(cargo dep *)",
      "Bash(rg --files)"
    ]
  },
  "preferredNotifChannel": "notifications_disabled",
  "spinnerTipsEnabled": false,
  "tui": "fullscreen",
  "verbose": true
}
